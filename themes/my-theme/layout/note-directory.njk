<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>{{ page.title }} - {{ config.title }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/note-directory.css">
</head>
<body class="note-directory-page">
    <div class="directory-container">
        <!-- 左侧归档侧边栏 -->
        <aside class="archive-sidebar">
            <h3>📂 归档</h3>
            <ul>
                <li><a href="/note/">所有笔记</a></li>
                <li><a href="/note/#2026">2026</a></li>
                <li><a href="/note/#2025">2025</a></li>
                <!-- 你可以动态生成或手写更多年份 -->
            </ul>
        </aside>

        <!-- 右侧主要内容区 -->
        <main class="directory-main">
            <div class="directory-header">
                <h1>{{ page.title }}</h1>
                <a href="/" class="home-link">← 返回首页</a>
            </div>

            <div class="directory-content">
                <!-- 这里会渲染你 index.md 里的内容 -->
                {{ page.content }}
            </div>
        </main>
    </div>

    <footer class="directory-footer">
        <p>{{ config.author }} · 森林与数字的交界处</p>
    </footer>
</body>
</html>

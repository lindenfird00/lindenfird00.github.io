<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ page.title }} - {{ config.title }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/note-directory.css">
    <style>
        /* 目录页专用样式 */
        body {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px 20px;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            color: #1d1d1f;
        }
        
        .site-title {
            font-size: 2.5rem;
            font-weight: 500;
            margin-bottom: 20px;
            color: #243010;
        }
        
        .nav {
            margin-bottom: 40px;
            padding-bottom: 15px;
            border-bottom: 1px solid #d2d2d7;
        }
        
        .nav a {
            color: #243010;
            text-decoration: none;
            margin-right: 25px;
            font-size: 1.1rem;
        }
        
        .nav a:hover {
            text-decoration: underline;
            color: #1a4d1a;
        }
        
        .note-list {
            list-style: none;
            padding: 0;
        }
        
        .note-list li {
            margin-bottom: 25px;
        }
        
        .note-list a {
            color: #243010;
            text-decoration: none;
            font-size: 1.2rem;
            line-height: 1.5;
        }
        
        .note-list a:hover {
            text-decoration: underline;
            color: #1a4d1a;
        }
        
        .note-list .desc {
            color: #666;
            font-size: 0.95rem;
            margin-left: 5px;
        }
        
        footer {
            margin-top: 60px;
            padding-top: 20px;
            border-top: 1px solid #d2d2d7;
            text-align: center;
            color: #86868b;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <h1 class="site-title">{{ config.title }}</h1>
    
    <nav class="nav">
        <a href="/">main</a>
        <a href="/oasis/">oasis</a>
        <a href="/inspire/">inspire</a>
        <a href="/me/">me</a>
    </nav>

    <main>
        {{ page.content }}
    </main>

    <footer>
        <p>{{ config.author }}</p>
    </footer>
</body>
</html>
